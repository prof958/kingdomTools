# ──────────────────────────────────────────────────
# KingdomTools Environment Variables
# Copy this to .env and fill in the values
# ──────────────────────────────────────────────────

# PostgreSQL
DATABASE_URL="postgresql://kingdomtools:CHANGE_ME@localhost:5432/kingdomtools"
POSTGRES_USER="kingdomtools"
POSTGRES_PASSWORD="CHANGE_ME"

# Auth — Generate APP_PASSWORD_HASH with: node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
APP_PASSWORD_HASH=""
SESSION_SECRET="CHANGE_ME_TO_A_RANDOM_STRING"

# App
NEXT_PUBLIC_APP_NAME="KingdomTools"
